# ===== CẤU HÌNH BẮT BUỘC =====

# Token bot Telegram - lấy từ @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Telegram ID của admin (dùng @userinfobot để lấy ID)
# Nhiều admin: ADMIN_IDS=123456789,987654321
ADMIN_IDS=123456789

# ===== ADMIN WEB PANEL =====
ADMIN_SECRET_KEY=change_this_to_random_string_xyz789
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@2024!
ADMIN_PORT=5000

# ===== THÔNG TIN NGÂN HÀNG =====
BANK_NAME=MB Bank
BANK_ACCOUNT=0123456789
BANK_OWNER=NGUYEN VAN A
BANK_BRANCH=Ha Noi

# ===== CÀI ĐẶT BOT =====
BOT_NAME=Shop Mã Xã Hội
SUPPORT_USERNAME=@your_support_username
MIN_DEPOSIT=10000

# ===== DATABASE =====
# SQLite (mặc định, dễ dùng)
DATABASE_URL=sqlite:///./bot_data.db

# PostgreSQL (khuyến nghị cho production)
# DATABASE_URL=postgresql://user:password@localhost:5432/botdb
